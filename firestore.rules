rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /reports/{reportId} {
      allow create: if true;
      allow read: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /incidents/{incidentId} {
      allow read: if true;
      allow write: if true;
    }

    match /hexcells/{cellId} {
      allow read: if true;
      allow write: if true;
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow write: if true;
    }

    match /pollutionSnapshots/{snapshotId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
  }
}
